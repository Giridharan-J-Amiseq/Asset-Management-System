# WorkSphere backend environment example
# Copy to `.env` (do not commit real secrets) and set your values.

# --- Database ---
WS_DB_HOST=localhost
WS_DB_PORT=5432
WS_DB_USER=postgres
WS_DB_PASSWORD=your_password
WS_DB_NAME=worksphere

# --- JWT ---
WS_SECRET_KEY=change-me
WS_TOKEN_EXPIRE_MINUTES=480

# --- Microsoft Entra ID (Azure AD) OAuth ---
# These must match your Azure App Registration.
AZURE_TENANT_ID=common
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Redirect URI must be registered in Azure as a Web redirect.
# For this project (backend-handled OAuth):
MS_REDIRECT_URI=http://127.0.0.1:8001/auth/microsoft/callback

# Where to send the browser after login completes (React dev server):
FRONTEND_URL=http://127.0.0.1:3000
